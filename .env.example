# Copy this file to .env and fill in your SMTP credentials to enable live email sending.
# If these are left unset, the server will gracefully fall back to logging
# inquiry submissions to the console — useful for local development.

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# Address inquiries are forwarded to
INQUIRY_TO_EMAIL=events@virtuosocatering.com
# The "from" address used when sending (often must match SMTP_USER on many providers)
INQUIRY_FROM_EMAIL=no-reply@virtuosocatering.com

PORT=3000
