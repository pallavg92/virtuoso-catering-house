# Copy this file to .env and fill in your SMTP credentials to enable live email sending.
# If these are left unset, the server will gracefully fall back to logging
# inquiry submissions to the console — useful for local development, but it
# means real visitor inquiries go nowhere, so this must be set in production.
#
# Using Gmail (virtuosocatering@gmail.com) as the sender:
# 1. Enable 2-Step Verification on the Google account.
# 2. Generate an App Password at https://myaccount.google.com/apppasswords
# 3. Use that 16-character password as SMTP_PASS below (remove spaces).

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=virtuosocatering@gmail.com
SMTP_PASS=your-16-character-app-password

# Address inquiries are forwarded to
INQUIRY_TO_EMAIL=virtuosocatering@gmail.com
# Gmail requires this to match SMTP_USER exactly
INQUIRY_FROM_EMAIL=virtuosocatering@gmail.com

PORT=3000
