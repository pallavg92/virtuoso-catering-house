<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
<%- include('partials/head') %>
</head>
<body class="<%= bodyClass %>">

<%- include('partials/preloader') %>
<%- include('partials/cursor') %>
<%- include('partials/nav') %>

<main id="smooth-wrapper">
<div id="smooth-content">

  <!-- HERO -->
  <section class="hero" id="hero">
    <div class="hero__media" data-parallax>
      <img src="<%= heroImage %>" alt="An elegantly plated dish at a candlelit dinner event" loading="eager">
    </div>
    <div class="hero__scrim"></div>
    <div class="hero__content">
      <span class="eyebrow eyebrow--light reveal-up">Boutique Luxury Catering</span>
      <h1 class="hero__title">
        <span class="reveal-line"><span>Culinary Artistry</span></span>
        <span class="reveal-line"><span>for Unforgettable</span></span>
        <span class="reveal-line"><span>Occasions</span></span>
      </h1>
      <p class="hero__subhead reveal-up">Virtuoso Catering House designs and executes bespoke menus for weddings, private clients, and the discerning exclusive brand event — one plate, one story at a time.</p>
      <div class="hero__actions reveal-up">
        <button type="button" class="btn btn--wine" data-magnetic data-inquire-trigger data-cursor="hover"><span>Inquire Now</span></button>
        <a href="/services" class="btn btn--ghost-light" data-magnetic data-cursor="hover"><span>View Services</span></a>
      </div>
    </div>
    <div class="hero__scroll-cue" aria-hidden="true">
      <span class="hero__scroll-line"></span>
      <span class="hero__scroll-label">Scroll</span>
    </div>
  </section>

  <!-- PHILOSOPHY -->
  <section class="philosophy section section--ivory">
    <div class="container">
      <span class="eyebrow reveal-up">Our Philosophy</span>
      <p class="philosophy__quote reveal-up">
        “We believe a meal is the only art form guests are invited to consume entirely.
        <em>Every course we send out is a sentence in a story</em> —
        considered, beautiful and built to be remembered.”
      </p>
      <div class="philosophy__attribution reveal-up">
        <span class="hairline hairline--gold"></span>
        <span>Aarti Sharma, Co-Founder</span>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services section section--charcoal">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow eyebrow--light reveal-up">What We Do</span>
        <h2 class="section-title reveal-up">Our Services</h2>
        <span class="section-header__line"></span>
      </div>

      <div class="services__grid">
        <% services.forEach(function(service, i) { %>
        <a href="/services" class="service-card reveal-up <%= i % 2 === 1 ? 'service-card--offset' : '' %>" data-cursor="hover">
          <div class="service-card__image">
            <img src="<%= service.image %>" alt="<%= service.title %> catering by Virtuoso Catering House" loading="lazy">
          </div>
          <div class="service-card__body">
            <span class="service-card__kicker"><%= service.kicker %></span>
            <h3 class="service-card__title"><%= service.title %></h3>
            <p class="service-card__copy"><%= service.copy %></p>
            <span class="link-underline">Learn More</span>
          </div>
        </a>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- OUR WORK -->
  <section class="our-work-home section section--ivory">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow reveal-up">Our Work</span>
        <h2 class="section-title reveal-up">Selected Occasions</h2>
        <span class="section-header__line"></span>
      </div>

      <div class="our-work__grid">
        <% ourWork.forEach(function(work) { %>
        <a href="/our-work" class="our-work-card reveal-up" data-cursor="hover">
          <img src="<%= work.image %>" alt="<%= work.title %>" loading="lazy">
          <div class="our-work-card__scrim"></div>
          <span class="our-work-card__title"><%= work.title %></span>
        </a>
        <% }); %>
      </div>

      <div class="our-work-home__cta reveal-up">
        <a href="/our-work" class="link-underline">View All Our Work</a>
      </div>
    </div>
  </section>

  <!-- BRAND QUOTE -->
  <section class="brand-quote section section--charcoal">
    <div class="container brand-quote__inner">
      <p class="brand-quote__text reveal-up">“<%= brandQuote %>”</p>
      <span class="hairline hairline--gold"></span>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section class="testimonials section section--ivory">
    <div class="container">
      <span class="eyebrow reveal-up">Client Words</span>
      <div class="testimonial-slider" id="testimonial-slider">
        <div class="testimonial-slider__track">
          <% testimonials.forEach(function(t, i) { %>
          <div class="testimonial-slide <%= i === 0 ? 'is-active' : '' %>" data-index="<%= i %>">
            <p class="testimonial-slide__quote">&ldquo;<%= t.quote %>&rdquo;</p>
            <div class="testimonial-slide__meta">
              <span class="testimonial-slide__name"><%= t.name %></span>
              <span class="testimonial-slide__role"><%= t.role %></span>
            </div>
          </div>
          <% }); %>
        </div>
        <div class="testimonial-slider__controls">
          <button class="testimonial-slider__arrow" id="testimonial-prev" aria-label="Previous testimonial" data-cursor="hover">←</button>
          <div class="testimonial-slider__dots" id="testimonial-dots">
            <% testimonials.forEach(function(t, i) { %>
            <button class="testimonial-slider__dot <%= i === 0 ? 'is-active' : '' %>" data-index="<%= i %>" aria-label="Go to testimonial <%= i + 1 %>"></button>
            <% }); %>
          </div>
          <button class="testimonial-slider__arrow" id="testimonial-next" aria-label="Next testimonial" data-cursor="hover">→</button>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner section section--wine">
    <div class="container cta-banner__inner">
      <h2 class="cta-banner__title reveal-up">Let’s Design Your<br>Next Occasion.</h2>
      <button type="button" class="btn btn--gold-outline" data-magnetic data-inquire-trigger data-cursor="hover"><span>Start an Inquiry</span></button>
    </div>
  </section>

<%- include('partials/footer') %>
</div>
</main>

<%- include('partials/scripts') %>
</body>
</html>
