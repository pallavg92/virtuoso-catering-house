<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
<%- include('partials/head') %>
</head>
<body class="<%= bodyClass %>">

<%- include('partials/preloader') %>
<%- include('partials/cursor') %>
<%- include('partials/nav') %>
<%- include('partials/whatsapp-float') %>
<%- include('partials/popups') %>

<main id="smooth-wrapper">
<div id="smooth-content">

  <!-- INTRO -->
  <section class="page-intro page-intro--short">
    <div class="page-intro__media" data-parallax>
      <img src="<%= heroImage %>" alt="Virtuoso Catering House on Instagram" loading="eager">
    </div>
    <div class="page-intro__scrim"></div>
    <div class="page-intro__content container">
      <%- include('partials/breadcrumb') %>
      <span class="eyebrow eyebrow--light reveal-up">Social Media</span>
      <h1 class="page-intro__title reveal-up">Follow<br>Along</h1>
    </div>
  </section>

  <!-- SOCIAL ACCOUNTS -->
  <section class="social-page section section--ivory">
    <div class="container">
      <p class="social-page__intro reveal-up">Events, menus, and behind-the-scenes moments from the Virtuoso team — across both of our Instagram accounts. This is where a tasting turns into a wedding menu, a brand brief becomes a fully staged product launch, and the small decisions — a garnish, a plating angle, a pour — get made in real time.</p>

      <div class="social-accounts">
        <% instagramAccounts.forEach(function(account) { %>
        <div class="social-account reveal-up">
          <div class="social-account__header">
            <div>
              <h3 class="social-account__name"><%= account.label %></h3>
              <span class="social-account__handle"><%= account.handle %></span>
            </div>
            <a href="<%= account.url %>" class="btn btn--outline-dark" target="_blank" rel="noopener noreferrer" data-cursor="hover"><span>Follow</span></a>
          </div>
          <p class="social-account__desc"><%= account.description %></p>
          <% if (account.embedUrl) { %>
          <div class="social-embed social-embed--live">
            <iframe src="<%= account.embedUrl %>" class="snapwidget-widget" allowtransparency="true" frameborder="0" scrolling="no" style="border:none; overflow:hidden; width:100%;" title="Instagram posts from <%= account.label %>"></iframe>
          </div>
          <% } else { %>
          <div class="social-embed" data-instagram-embed="<%= account.handle %>">
            <span class="social-embed__mark">IG</span>
            <p class="social-embed__text">Live feed embed coming soon</p>
          </div>
          <% } %>
        </div>
        <% }); %>

        <% if (instagramAccounts.some(function(a) { return a.embedUrl; })) { %>
        <script src="https://snapwidget.com/js/snapwidget.js"></script>
        <% } %>
      </div>
    </div>
  </section>

  <!-- WHAT YOU'LL FIND -->
  <section class="social-page__extra section section--ivory">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow reveal-up">On the Feed</span>
        <h2 class="section-title reveal-up">What You'll Find</h2>
        <span class="section-header__line"></span>
      </div>
      <div class="blog-post__prose">
        <p class="blog-post__copy reveal-up">@virtuosocateringhouse is our main account, and the closest thing to a running diary of the studio — finished tablescapes from weddings across Delhi NCR, the staging behind brand activations like our Lamborghini and Tesla launches, and tasting-room moments that never make it onto the website. Expect a mix of finished event photography and rougher, in-the-moment video from setup days.</p>
        <p class="blog-post__copy reveal-up">@thefirstpourbyvirtuoso is where the bar team lives — cocktail programs built around a couple's story, batch-crafted pours for large guest counts, and the live mixology stations we run at brand events. If you're planning a wedding or a launch and want to see how we treat beverage as its own course rather than an afterthought, this is the account to follow.</p>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner section section--wine">
    <div class="container cta-banner__inner">
      <h2 class="cta-banner__title reveal-up">See More of<br>Our World.</h2>
      <a href="<%= instagramAccounts[0].url %>" class="btn btn--gold-outline" data-magnetic target="_blank" rel="noopener noreferrer" data-cursor="hover"><span>Visit Our Instagram</span></a>
    </div>
  </section>

<%- include('partials/footer') %>
</div>
</main>

<%- include('partials/scripts') %>
</body>
</html>
