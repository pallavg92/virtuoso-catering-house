<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
<%- include('partials/head') %>
</head>
<body class="<%= bodyClass %>">

<%- include('partials/preloader') %>
<%- include('partials/cursor') %>
<%- include('partials/nav') %>

<main id="smooth-wrapper">
<div id="smooth-content">

  <!-- INTRO -->
  <section class="page-intro">
    <div class="page-intro__media" data-parallax>
      <img src="<%= aboutHeroImage %>" alt="A candlelit plated dish by Virtuoso Catering House" loading="eager">
    </div>
    <div class="page-intro__scrim"></div>
    <div class="page-intro__content container">
      <span class="eyebrow eyebrow--light reveal-up">About Virtuoso Catering House</span>
      <h1 class="page-intro__title reveal-up">Where Every Detail<br>Becomes the Experience</h1>
    </div>
  </section>

  <!-- FOUNDERS -->
  <section class="founders section section--ivory">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow reveal-up">The Founders</span>
        <h2 class="section-title reveal-up">Aarti Sharma &amp; Pallav Goel</h2>
        <span class="section-header__line"></span>
      </div>

      <div class="founders__grid">
        <% founders.forEach(function(founder) { %>
        <div class="founder-block reveal-up">
          <div class="founder-block__image">
            <img src="<%= founder.image %>" alt="<%= founder.name %>, <%= founder.role %> of Virtuoso Catering House" loading="lazy">
          </div>
          <span class="eyebrow eyebrow--gold"><%= founder.role %></span>
          <h3 class="founder-block__name"><%= founder.name %></h3>
          <p class="founder-block__bio"><%= founder.bio %></p>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <% founders.forEach(function(founder) { %>
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "name": "<%= founder.name %>",
    "jobTitle": "<%= founder.role %>",
    "description": "<%- JSON.stringify(founder.bio).slice(1, -1) %>",
    "image": "<%= siteUrl %><%= founder.image %>",
    "url": "<%= siteUrl %>/about",
    "worksFor": {
      "@type": "Organization",
      "name": "<%= business.name %>",
      "url": "<%= siteUrl %>"
    },
    "sameAs": ["<%= founder.linkedin %>"]
  }
  </script>
  <% }); %>

  <!-- HOW WE WORK -->
  <section class="timeline section section--charcoal">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow eyebrow--light reveal-up">How We Work</span>
        <h2 class="section-title reveal-up">From Brief to Final Night</h2>
        <span class="section-header__line"></span>
      </div>

      <div class="timeline__list" id="timeline-list">
        <div class="timeline__progress" id="timeline-progress"></div>
        <% process.forEach(function(item, i) { %>
        <div class="timeline__item reveal-up">
          <span class="timeline__year"><%= item.step %></span>
          <div class="timeline__dot"></div>
          <div class="timeline__body">
            <h3><%= item.title %></h3>
            <p><%= item.copy %></p>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner section section--wine">
    <div class="container cta-banner__inner">
      <h2 class="cta-banner__title reveal-up">Ready to Start<br>the Conversation?</h2>
      <button type="button" class="btn btn--gold-outline" data-magnetic data-inquire-trigger data-cursor="hover"><span>Start an Inquiry</span></button>
    </div>
  </section>

<%- include('partials/footer') %>
</div>
</main>

<%- include('partials/scripts') %>
</body>
</html>
