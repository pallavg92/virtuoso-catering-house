<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
<%- include('partials/head') %>
</head>
<body class="<%= bodyClass %>">

<%- include('partials/preloader') %>
<%- include('partials/cursor') %>
<%- include('partials/nav') %>
<%- include('partials/whatsapp-float') %>
<%- include('partials/popups') %>

<main id="smooth-wrapper">
<div id="smooth-content">

  <!-- INTRO -->
  <section class="page-intro page-intro--short">
    <div class="page-intro__media" data-parallax>
      <img src="<%= servicesHeroImage %>" alt="Virtuoso Catering House — Weddings, Brand Activations, Mixology, and Bespoke Menus" loading="eager">
    </div>
    <div class="page-intro__scrim"></div>
    <div class="page-intro__content container">
      <%- include('partials/breadcrumb') %>
      <span class="eyebrow eyebrow--light reveal-up">Services</span>
      <h1 class="page-intro__title reveal-up">Every Detail,<br>Considered</h1>
    </div>
  </section>

  <!-- SERVICE POSTS -->
  <section class="service-posts section section--ivory">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow reveal-up">What We Do</span>
        <h2 class="section-title reveal-up">Our Services</h2>
        <span class="section-header__line"></span>
      </div>

      <div class="service-posts__grid">
        <% services.forEach(function(service) { %>
        <article class="service-post-card reveal-up" data-cursor="hover">
          <div class="service-post-card__image">
            <img src="<%= service.image %>" alt="<%= service.title %> catering by Virtuoso Catering House" loading="lazy">
          </div>
          <span class="service-post-card__kicker"><%= service.kicker %></span>
          <h3 class="service-post-card__title"><%= service.title %></h3>
          <p class="service-post-card__copy"><%= service.copy %></p>
          <% if (service.slug === 'brand-activations') { %>
          <a href="/luxury-brand-event-catering-delhi-ncr" class="link-underline">Read More</a>
          <% } else if (service.slug === 'weddings') { %>
          <a href="/luxury-wedding-catering-delhi-ncr" class="link-underline">Read More</a>
          <% } else { %>
          <a href="#menu-panels" class="link-underline">View Sample Menu</a>
          <% } %>
        </article>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- MENU -->
  <section class="menu-page section section--ivory">
    <div class="container">
      <div class="menu-page__header">
        <div>
          <span class="eyebrow reveal-up">Sample Offerings</span>
          <h2 class="section-title reveal-up">A Working Menu</h2>
          <p class="menu-page__intro reveal-up">Every engagement begins with a private tasting. The selections below represent a starting point — final menus are always written around your event, your guests, and the season.</p>
        </div>
        <button type="button" class="btn btn--outline-dark" data-menu-download-trigger data-cursor="hover">
          <span>Download Full Menu (PDF)</span>
        </button>
      </div>

      <div class="menu-tabs" id="menu-tabs" role="tablist" aria-label="Menu categories">
        <% menu.categories.forEach(function(cat, i) { %>
        <button class="menu-tabs__btn <%= i === 0 ? 'is-active' : '' %>" role="tab" aria-selected="<%= i === 0 %>" data-category="<%= cat.slug %>" data-cursor="hover"><%= cat.label %></button>
        <% }); %>
      </div>

      <div class="menu-panels" id="menu-panels">
        <% menu.categories.forEach(function(cat, i) { %>
        <div class="menu-panel <%= i === 0 ? 'is-active' : '' %>" data-category-panel="<%= cat.slug %>">
          <div class="menu-list">
            <% cat.items.forEach(function(item) { %>
            <div class="menu-row">
              <div class="menu-row__main">
                <h3 class="menu-row__name"><%= item.name %></h3>
                <p class="menu-row__desc"><%= item.desc %></p>
              </div>
              <% if (item.tags.length) { %>
              <div class="menu-row__tags">
                <% item.tags.forEach(function(tag) { %>
                <span class="diet-tag" title="<%= tag === 'V' ? 'Vegetarian' : tag === 'GF' ? 'Gluten-Free' : tag === 'DF' ? 'Dairy-Free' : tag %>"><%= tag %></span>
                <% }); %>
              </div>
              <% } %>
            </div>
            <% }); %>
          </div>
        </div>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- AREAS WE SERVE -->
  <section class="explore-links section section--ivory">
    <div class="container">
      <div class="section-header">
        <span class="eyebrow reveal-up">Areas We Serve</span>
        <h2 class="section-title reveal-up">Catering Across Delhi NCR</h2>
        <span class="section-header__line"></span>
      </div>
      <div class="explore-links__grid">
        <% commercialPages.forEach(function(page) { %>
        <a href="<%= page.path %>" class="explore-links__item reveal-up" data-cursor="hover">
          <span class="explore-links__label"><%= page.label %></span>
          <p class="explore-links__blurb"><%= page.blurb %></p>
        </a>
        <% }); %>
      </div>
    </div>
  </section>

  <!-- CTA BANNER -->
  <section class="cta-banner section section--wine">
    <div class="container cta-banner__inner">
      <h2 class="cta-banner__title reveal-up">Have a Menu<br>in Mind?</h2>
      <button type="button" class="btn btn--gold-outline" data-magnetic data-inquire-trigger data-cursor="hover"><span>Request a Tasting</span></button>
    </div>
  </section>

<%- include('partials/footer') %>
</div>
</main>

<%- include('partials/scripts') %>
</body>
</html>
