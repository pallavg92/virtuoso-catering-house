<!DOCTYPE html>
<html lang="en" class="no-js">
<head>
<%- include('partials/head') %>
</head>
<body class="<%= bodyClass %>">

<%- include('partials/preloader') %>
<%- include('partials/cursor') %>
<%- include('partials/nav') %>
<%- include('partials/whatsapp-float') %>

<main id="smooth-wrapper">
<div id="smooth-content">
<% const sortedPosts = blogPosts.slice().sort(function(a, b) { return new Date(b.date) - new Date(a.date); }); %>

  <!-- INTRO -->
  <section class="page-intro page-intro--short">
    <div class="page-intro__media" data-parallax>
      <img src="<%= blogHeroImage %>" alt="Notes from the Virtuoso Catering House team" loading="eager">
    </div>
    <div class="page-intro__scrim"></div>
    <div class="page-intro__content container">
      <%- include('partials/breadcrumb') %>
      <span class="eyebrow eyebrow--light reveal-up">Journal</span>
      <h1 class="page-intro__title reveal-up">Notes on the<br>Craft</h1>
    </div>
  </section>

  <!-- BLOG LIST -->
  <section class="blog-page section section--ivory">
    <div class="container">
      <p class="blog-page__intro reveal-up">Thoughts on event design, hospitality, and the craft of luxury catering — updated as we publish.</p>

      <div class="blog-list">
        <% sortedPosts.forEach(function(post) { %>
        <a href="<%= post.url || '/blog' %>" class="blog-row reveal-up" data-cursor="hover">
          <div class="blog-row__image">
            <img src="<%= post.image %>" alt="<%= post.title %>" loading="lazy">
          </div>
          <div class="blog-row__body">
            <span class="blog-row__date"><%= new Date(post.date).toLocaleDateString('en-IN', { year: 'numeric', month: 'long', day: 'numeric' }) %></span>
            <h2 class="blog-row__title"><%= post.title %></h2>
            <p class="blog-row__excerpt"><%= post.excerpt %></p>
          </div>
        </a>
        <% }); %>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
</div>
</main>

<%- include('partials/scripts') %>
</body>
</html>
